function guardarEmpresa_(e){if(!e||!e.Empresa||!e.CorreoDoctor)throw new Error('Empresa y correo médico son obligatorios');const sh=sheet_(SHEET_EMP),nombre=String(e.Empresa).trim();const ex=rows_(sh).find(x=>String(x.Empresa).trim().toLowerCase()===nombre.toLowerCase());setRowByHeader_(sh,ex?ex.__row:sh.getLastRow()+1,{Empresa:nombre,CorreoDoctor:String(e.CorreoDoctor).trim()});return{saved:true}}
function buscarTrabajador_(dni){const d=String(dni||'').trim();if(!/^\d{8}$/.test(d))throw new Error('DNI debe tener 8 dígitos');const f=rows_(sheet_(SHEET_TRAB)).find(r=>String(r.DNI).trim()===d&&String(r.Estado||'ACTIVO').toUpperCase()!=='INACTIVO');return{trabajador:f||null}}
function guardarTrabajador_(t){if(!t||!/^\d{8}$/.test(String(t.DNI||'').trim()))throw new Error('DNI debe tener 8 dígitos');['Nombres','Cargo','Empresa','Sede','Correo','Celular','Estado'].forEach(k=>{if(!String(t[k]||'').trim())throw new Error('Todos los campos son obligatorios')});const sh=sheet_(SHEET_TRAB);sh.getRange('A:A').setNumberFormat('@');sh.getRange('H:H').setNumberFormat('@');const dni=String(t.DNI).trim(),ex=rows_(sh).find(x=>String(x.DNI).trim()===dni);setRowByHeader_(sh,ex?ex.__row:sh.getLastRow()+1,{DNI:dni,Nombres:t.Nombres||'',Cargo:t.Cargo||'',Empresa:t.Empresa||'',Sede:t.Sede||'',Rubro:t.Rubro||'',Correo:t.Correo||'',Celular:String(t.Celular||''),Estado:t.Estado||'ACTIVO',FechaRegistro:new Date()});return{saved:true}}
