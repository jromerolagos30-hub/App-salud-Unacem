function ss_(){return SpreadsheetApp.openById(SPREADSHEET_ID)} function sheet_(n){return ss_().getSheetByName(n)||ss_().insertSheet(n)} function json_(o){return ContentService.createTextOutput(JSON.stringify(o)).setMimeType(ContentService.MimeType.JSON)}
function setup_(){const t=sheet_(SHEET_TRAB);setHeaders_(t,['DNI','Nombres','Cargo','Empresa','Sede','Rubro','Correo','Celular','Estado','FechaRegistro']);t.getRange('A:A').setNumberFormat('@');t.getRange('H:H').setNumberFormat('@');const r=sheet_(SHEET_REP);setHeaders_(r,['Fecha','DNI','Nombres','Cargo','Empresa','Sede','Rubro','Correo','Celular','EjecutaAltoRiesgo','Condicion','ActividadesJSON','SintomasJSON','ComentarioAdicional','DeclaracionVeraz','PDFEnviado','CorreoDoctorEnviado']);r.getRange('B:B').setNumberFormat('@');r.getRange('I:I').setNumberFormat('@');const e=sheet_(SHEET_EMP);setHeaders_(e,['Empresa','CorreoDoctor']);}
function setHeaders_(sh,headers){if(sh.getLastRow()<1){sh.appendRow(headers);return}const cur=sh.getRange(1,1,1,Math.max(sh.getLastColumn(),headers.length)).getDisplayValues()[0];headers.forEach((h,i)=>{if(String(cur[i]||'').trim()!==h)sh.getRange(1,i+1).setValue(h)})}
function headerMap_(sh){const h=sh.getRange(1,1,1,sh.getLastColumn()).getDisplayValues()[0],m={};h.forEach((x,i)=>m[String(x).trim()]=i+1);return m}
function setRowByHeader_(sh,row,obj){const m=headerMap_(sh);Object.keys(obj).forEach(k=>{if(m[k])sh.getRange(row,m[k]).setValue(obj[k])})}
function rows_(sh){const v=sh.getDataRange().getDisplayValues();if(v.length<2)return[];const h=v.shift();return v.filter(r=>r.join('')!=='').map((row,idx)=>{const o={};h.forEach((x,i)=>o[String(x).trim()]=row[i]);o.__row=idx+2;return o})}
function esc_(v){return String(v||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')} function parseJSON_(s){try{return JSON.parse(s||'{}')}catch(e){return{}}}
function fechaKey_(v){const s=String(v||'').trim();if(!s)return'';const m=s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})/);if(m)return m[3]+'-'+String(m[2]).padStart(2,'0')+'-'+String(m[1]).padStart(2,'0');const d=new Date(v);if(isNaN(d.getTime()))return'';return Utilities.formatDate(d,Session.getScriptTimeZone(),'yyyy-MM-dd')}
function formatoFechaReporte_(v){const s=String(v||'').trim();if(!s)return'';if(s.includes('/'))return s;const d=new Date(v);if(isNaN(d.getTime())||d.getFullYear()<2000)return s;return Utilities.formatDate(d,Session.getScriptTimeZone(),'dd/MM/yyyy HH:mm')}
function isConSintomas_(c){c=String(c||'').toUpperCase().trim();return c==='CON SÍNTOMAS'||c==='CON SINTOMAS'||c.includes('ALERTA')} function isSinSintomas_(c){c=String(c||'').toUpperCase().trim();return c==='SIN SÍNTOMAS'||c==='SIN SINTOMAS'}
